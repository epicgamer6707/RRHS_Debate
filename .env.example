# Copy to ".env" on the server and fill in. docker compose reads this.
# Generate SECRET_KEY and DB_PASSWORD with: openssl rand -hex 32

DOMAIN=debate.yourdomain.com
DB_PASSWORD=change-me-to-a-long-random-string
SECRET_KEY=change-me-to-a-long-random-string

# Officers who can post to the Classroom (comma-separated). Leave blank = everyone.
OFFICER_EMAILS=

# Google sign-in (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Password-reset email (Resend)
RESEND_API_KEY=
MAIL_FROM=RRHS Debate <onboarding@resend.dev>

# Competition signups (Slack incoming webhook)
SLACK_WEBHOOK_URL=

# Classroom document storage (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=classroom-files
